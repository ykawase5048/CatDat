{
	"name": "catdat",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:host": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"prepare": "husky",
		"db:shell": "sqlite3 database/local.db",
		"db:seed": "./scripts/seed.sh",
		"db:deduce-implications": "npx vite-node --options.transformMode.ssr='/.*/' src/lib/scripts/deduce-implications.ts",
		"db:deduce-properties": "npx vite-node --options.transformMode.ssr='/.*/' src/lib/scripts/deduce-properties.ts",
		"db:create": "pnpm db:seed && pnpm db:deduce-implications && pnpm db:deduce-properties"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-netlify": "^5.2.4",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^25.0.3",
		"husky": "^9.1.7",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.46.0",
		"svelte-check": "^4.3.5",
		"typescript": "^5.9.3",
		"vite": "^7.3.0"
	},
	"engines": {
		"node": ">=22.13.0"
	},
	"dependencies": {
		"@fortawesome/free-regular-svg-icons": "^7.1.0",
		"@fortawesome/free-solid-svg-icons": "^7.1.0",
		"@libsql/client": "^0.17.0",
		"@types/katex": "^0.16.7",
		"katex": "^0.16.27",
		"sql-template-tag": "^5.2.1",
		"svelte-fa": "^4.0.4"
	}
}
