{
	"name": "catdat",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:remote": "vite dev --mode prod",
		"dev:host": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"prepare": "husky",
		"db:shell": "sqlite3 database/local.db",
		"db:kill": "rm -rf database/local.db",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:seed": "tsx scripts/seed.ts",
		"db:deduce": "tsx scripts/deduce.ts",
		"db:test": "tsx scripts/test.ts",
		"db:update": "pnpm db:migrate && pnpm db:seed && pnpm db:deduce && pnpm db:test",
		"db:watch": "tsx scripts/watch.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/katex": "^0.16.8",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.5.0",
		"chokidar": "^5.0.0",
		"dotenv": "^17.3.1",
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.3"
	},
	"engines": {
		"node": ">=22.13.0"
	},
	"dependencies": {
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@libsql/client": "^0.17.2",
		"@octokit/app": "^16.1.2",
		"chart.js": "^4.5.1",
		"es6-crawler-detect": "^4.0.2",
		"ioredis": "^5.10.1",
		"katex": "^0.16.44",
		"leo-profanity": "^1.9.0",
		"markdown-it": "^14.1.1",
		"sql-template-tag": "^5.2.1",
		"svelte-chartjs": "^4.0.1",
		"svelte-fa": "^4.0.4"
	}
}
