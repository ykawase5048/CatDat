{
	"name": "catdat",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:remote": "vite dev --mode prod",
		"dev:host": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"prepare": "husky",
		"db:shell": "sqlite3 database/local.db",
		"db:seed": "./scripts/seed.sh",
		"db:deduce-implications": "vite-node --options.transformMode.ssr='/.*/' src/lib/scripts/deduce-implications.ts",
		"db:deduce-properties": "vite-node --options.transformMode.ssr='/.*/' src/lib/scripts/deduce-properties.ts",
		"db:create": "pnpm db:seed && pnpm db:deduce-implications && pnpm db:deduce-properties",
		"db:check": "vite-node --options.transformMode.ssr='/.*/' src/lib/scripts/check.ts",
		"db:shell:remote": "turso db shell catdat",
		"db:seed:remote": "./scripts/seed_remote.sh",
		"db:deduce-implications:remote": "vite-node --mode prod --options.transformMode.ssr='/.*/' src/lib/scripts/deduce-implications.ts",
		"db:deduce-properties:remote": "vite-node --mode prod --options.transformMode.ssr='/.*/' src/lib/scripts/deduce-properties.ts",
		"db:create:remote": "pnpm db:seed:remote && pnpm db:deduce-implications:remote && pnpm db:deduce-properties:remote",
		"db:check:remote": "vite-node --mode prod --options.transformMode.ssr='/.*/' src/lib/scripts/check.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/katex": "^0.16.8",
		"@types/node": "^25.5.0",
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.11",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vite-node": "^6.0.0"
	},
	"engines": {
		"node": ">=22.13.0"
	},
	"dependencies": {
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@libsql/client": "^0.17.0",
		"katex": "^0.16.38",
		"sql-template-tag": "^5.2.1",
		"svelte-fa": "^4.0.4"
	}
}
